<view class="ai-page"><scroll-view class="chat" style="{{'height:'+(chatHeight+'px')+';'}}" scroll-y="{{true}}" scroll-top="{{scrollTop}}"><block wx:if="{{!$root.g0}}"><view class="welcome"><image class="avatar" src="../../static/images/ai-h.png" mode="widthFix"></image><view class="hi">你好，我是景区AI助手</view><view class="sub">问我木鱼湖周边的吃喝玩乐、路线、景点吧～</view></view></block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="i" wx:key="i"><view class="{{['row',item.role]}}"><view class="bubble">{{item.text}}</view></view></block><block wx:if="{{loading}}"><view class="row assistant"><view class="bubble typing">思考中...</view></view></block></scroll-view><view class="inputbar"><input class="ipt" type="text" placeholder="请输入你的问题" confirm-type="send" data-event-opts="{{[['confirm',[['send',['$event']]]],['input',[['__set_model',['','text','$event',[]]]]]]}}" value="{{text}}" bindconfirm="__e" bindinput="__e"/><button class="sendbtn" disabled="{{$root.g1}}" data-event-opts="{{[['tap',[['send',['$event']]]]]}}" bindtap="__e">发送</button></view></view>