.map-page {
  position: relative;
  width: 100%;
}
.map-page .map {
  display: block;
  width: 100%;
}
.map-page .legend {
  position: fixed;
  left: 30rpx;
  bottom: 180rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}
.map-page .legend .item {
  display: flex;
  align-items: center;
  line-height: 2;
}
.map-page .legend .dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.map-page .legend .dot.blue {
  background: #1a73e8;
}
.map-page .legend .dot.red {
  background: #ff3b30;
}
.map-page .legend .count {
  margin-top: 6rpx;
  color: #31C27C;
  font-weight: bold;
}
.map-page .sos-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 20;
}
.map-page .sos-bar .sos-btn {
  width: 86%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 6rpx 18rpx rgba(255, 59, 48, 0.4);
}
.map-page .sos-bar .sos-btn::after {
  border: none;
}
.map-page .sos-bar .sos-btn[disabled] {
  opacity: 0.6;
}
