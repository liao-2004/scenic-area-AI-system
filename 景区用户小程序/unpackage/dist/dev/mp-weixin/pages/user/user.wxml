<view class="user"><view class="account"><block wx:if="{{userInfo}}"><block><view class="nick">{{userInfo.nickname||'微信用户'}}</view><view data-event-opts="{{[['tap',[['handleLogout',['$event']]]]]}}" class="logout" bindtap="__e">退出登录</view></block></block><block wx:else><view data-event-opts="{{[['tap',[['goLogin',['$event']]]]]}}" class="loginentry" bindtap="__e">点击登录</view></block></view><view class="top"><image src="../../static/images/history.png" mode></image><view class="text">浏览历史</view><block wx:if="{{$root.g0}}"><view data-event-opts="{{[['tap',[['clearHistory',['$event']]]]]}}" class="clear" bindtap="__e">清除历史记录</view></block></view><view class="content"><block wx:for="{{listArr}}" wx:for-item="item" wx:for-index="__i0__"><view class="row"><newsbox vue-id="{{'380011e0-1-'+__i0__}}" item="{{item}}" data-event-opts="{{[['tap',[['goDetail',['$0'],[[['listArr','',__i0__]]]]]]]}}" bindtap="__e" bind:__l="__l"></newsbox></view></block></view><block wx:if="{{!$root.g1}}"><view class="nohistory"><image src="../../static/images/nohis.png" mode="widthFix"></image><view class="text">暂无浏览记录</view></view></block></view>