.ai-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F2F3F5;
}
.ai-page .chat {
  padding: 24rpx;
  box-sizing: border-box;
}
.ai-page .chat .welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}
.ai-page .chat .welcome .avatar {
  width: 120rpx;
}
.ai-page .chat .welcome .hi {
  font-size: 34rpx;
  color: #333;
  font-weight: bold;
  margin-top: 20rpx;
}
.ai-page .chat .welcome .sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}
.ai-page .chat .row {
  display: flex;
  margin-bottom: 24rpx;
}
.ai-page .chat .row.user {
  justify-content: flex-end;
}
.ai-page .chat .row.assistant {
  justify-content: flex-start;
}
.ai-page .chat .row .bubble {
  max-width: 76%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}
.ai-page .chat .row.user .bubble {
  background: #31C27C;
  color: #fff;
  border-top-right-radius: 4rpx;
}
.ai-page .chat .row.assistant .bubble {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}
.ai-page .chat .row .typing {
  color: #999;
}
.ai-page .inputbar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.ai-page .inputbar .ipt {
  flex: 1;
  height: 72rpx;
  background: #F2F3F5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
}
.ai-page .inputbar .sendbtn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 0 0 20rpx;
  padding: 0;
  font-size: 30rpx;
  color: #fff;
  background: #31C27C;
  border-radius: 36rpx;
}
.ai-page .inputbar .sendbtn[disabled] {
  background: #a8d8c0;
}
